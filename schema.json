{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.appdmg.dev/appdmg.schema.json",
  "title": "appdmg specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "contents"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "background": {
      "type": "string"
    },
    "background-color": {
      "type": "string",
      "format": "css-color"
    },
    "icon-size": {
      "type": "integer"
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/point"
        },
        "size": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            }
          }
        }
      }
    },
    "format": {
      "type": "string",
      "enum": [
        "UDRW",
        "UDRO",
        "UDCO",
        "UDZO",
        "ULFO",
        "ULMO",
        "UDBZ"
      ]
    },
    "filesystem": {
      "type": "string",
      "enum": [
        "HFS+",
        "APFS"
      ]
    },
    "contents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "type",
          "path"
        ],
        "properties": {
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": [
              "link",
              "file",
              "position"
            ]
          },
          "path": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "code-sign": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signing-identity"
      ],
      "properties": {
        "signing-identity": {
          "type": "string"
        },
        "identifier": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      }
    }
  }
}
